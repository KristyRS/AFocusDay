# Copy this file to .env and fill in your real values. .env is gitignored — never commit it.

# Azure AD (Entra ID) app registration — Authentication > Platform: Single-page application
MSAL_CLIENT_ID=
MSAL_TENANT_ID=common
MSAL_REDIRECT_URI=http://localhost:3000

# Google Cloud OAuth 2.0 Client ID (type: Web application) — not secret, safe
# to expose to the browser like MSAL_CLIENT_ID. Needs the Gmail API enabled
# and http://localhost:3000 (or your real domain) as an authorized origin.
GOOGLE_CLIENT_ID=

# Anthropic API key from console.anthropic.com — kept server-side, never sent to the browser
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

PORT=3000
